# ══════════════════════════════════════════════════════════════════
# JFrog Platform Demos — Environment Configuration
# ══════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
#
# Quick start:
#   cp .env.example .env
#   # edit .env with your values
#   ./setup/validate.sh    # checks everything is correct
#   ./setup/bootstrap.sh   # creates repos, watches, policies
#   ./setup/prep.sh        # seeds SwiftShip with vulnerabilities
# ══════════════════════════════════════════════════════════════════

# ── Required ────────────────────────────────────────────────────
# Your JFrog Cloud instance URL (no trailing slash)
JFROG_URL=https://YOUR-INSTANCE.jfrog.io

# Access token with Admin or Project-Admin permissions
# Generate at: https://YOUR-INSTANCE.jfrog.io/ui/admin/identity/access-tokens
JFROG_TOKEN=your-access-token-here

# Your JFrog user email (used for CLI config)
JFROG_USER=your-email@company.com

# ── JFrog CLI Server ID ──────────────────────────────────────────
# Run "jf c show" to list your configured servers.
# Set this to the Server ID of the instance you want to run
# the SwiftShip demo on.
# Example: LiquidJedi, avi-jf-demo, myinstance
JF_SERVER_ID=LiquidJedi

# ── Shared Instance Namespacing ──────────────────────────────────
# Leave empty if you have a dedicated instance.
# Set to a short unique key (e.g. "se-alice") if sharing an instance
# with other SolEng engineers. All repos and policies will be prefixed
# with this key so engineers don't collide.
JFROG_PROJECT_KEY=

# Prefix for all Artifactory repos created by bootstrap.sh
# Default: "demo"  →  repos named demo-npm-dev, demo-npm-prod, etc.
# If using a project key: "se-alice-demo"
JFROG_REPO_PREFIX=demo

# ── Demo Scope ───────────────────────────────────────────────────
# Comma-separated list of traditional package types to bootstrap.
# Comment out any you don't need to speed up bootstrap.
DEMO_PACKAGES=maven,npm,pypi,docker,go,nuget,helm,gradle

# AI/ML package types (newer features — confirm your instance supports them)
DEMO_AI_PACKAGES=huggingface,ml,oci,mcp,skills,agent-plugins,ai-editor-ext

# ── GitHub Integration (for Frogbot & OIDC) ─────────────────────
# GitHub personal access token with repo + workflow permissions
GITHUB_TOKEN=your-github-token-here

# The repo Frogbot will scan (format: org/repo)
GITHUB_REPO=your-org/jfrog-platform-demos

# JFrog OIDC provider name — enables zero-secret CI auth (no token in secrets).
# Format: org/repo@github  (e.g. Liquid-Frog/JFROG-PLATFORM-DEMOS@github)
# This value is auto-created by the JFrog GitHub App when you connect your repo.
# Steps: JFrog Platform → Administration → Integrations → GitHub App → Connect repo.
# After connecting, copy the generated provider name and set it here.
# SolEng engineers cloning this template: replace "Liquid-Frog/JFROG-PLATFORM-DEMOS"
# with your own org/repo — the "@github" suffix is always literal.
JFROG_OIDC_PROVIDER_NAME=Liquid-Frog/JFROG-PLATFORM-DEMOS@github

# ── MCP Server (Cursor / Claude Code / Codex demo) ──────────────
# Enable the JFrog MCP Server first:
# https://docs.jfrog.com/integrations/docs/enable-the-jfrog-mcp-server
# Then use your instance URL — the MCP endpoint is at /mcp
JFROG_MCP_URL=https://YOUR-INSTANCE.jfrog.io/mcp

# ── Runtime Scanning (Stage E demo — optional) ──────────────────
# Path to kubeconfig for the demo Kubernetes cluster
KUBECONFIG=~/.kube/config

# Name of the demo cluster context
RUNTIME_CLUSTER_CONTEXT=demo-cluster

# Namespace where SwiftShip runs in the demo cluster
RUNTIME_NAMESPACE=swiftship-demo

# ── Notification Integrations (optional) ────────────────────────
# Slack webhook for Xray violation alerts (optional)
SLACK_WEBHOOK_URL=

# ── AppTrust (automatically uses JFROG_URL + JFROG_TOKEN) ───────
# AppTrust is accessed via the same JFrog instance.
# No extra config needed — bootstrap.sh creates the Applications.
# Docs: https://docs.jfrog.com/governance/docs/jfrog-apptrust
